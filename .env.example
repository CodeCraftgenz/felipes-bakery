# ============================================================
# Felipe's Bakery — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env.local (dev) ou .env.production (prod)
# NUNCA commite arquivos .env com valores reais no repositório
#
# Para deploy na Hostinger Node.js Web App, configure estas variáveis no
# painel da Hostinger → Node.js Web App → Environment Variables.
# Variáveis marcadas como (obrigatória) precisam estar definidas em produção.
# ============================================================

# ─── App ──────────────────────────────────────────────────
# Ambiente de execução — sempre 'production' em produção
NODE_ENV=development

# URL pública do site (obrigatória em produção)
# Usada para gerar links absolutos em e-mails, webhooks, OG images, etc.
# Em produção: https://felipesbakery.com.br
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Porta HTTP — a Hostinger injeta automaticamente; em dev usa 3000
# PORT=3000

# ─── Banco de Dados (MySQL) ────────────────────────────────
# (obrigatória) Formato: mysql://usuario:senha@host:porta/banco
# Hostinger: copie do painel → Databases → criar database MySQL,
# anote host (geralmente 'localhost' ou um host interno), nome, usuário e senha,
# depois monte: mysql://USER:PASS@HOST:3306/DATABASE
DATABASE_URL=mysql://bakery_user:bakery_dev_password@localhost:3306/felipesbakery_dev

# Variáveis individuais (usadas apenas pelo docker-compose.prod.yml local)
# Não são necessárias na Hostinger — pode deixar em branco lá.
MYSQL_ROOT_PASSWORD=TROCAR_senha_root_forte_aqui
MYSQL_DATABASE=felipesbakery_prod
MYSQL_USER=bakery_user
MYSQL_PASSWORD=TROCAR_senha_forte_aqui

# ─── NextAuth.js v5 ────────────────────────────────────────
# (obrigatória) Segredo para assinar JWT — gere com:
#   openssl rand -base64 32
# Atenção: o NextAuth v5 lê AUTH_SECRET; mantemos NEXTAUTH_SECRET como alias
# por compatibilidade, mas defina AUTH_SECRET em produção.
AUTH_SECRET=TROCAR_segredo_gerado_com_openssl_rand_base64_32
NEXTAUTH_SECRET=TROCAR_segredo_gerado_com_openssl_rand_base64_32

# (obrigatória) URL canônica do site (mesma do NEXT_PUBLIC_APP_URL)
# Em produção: https://felipesbakery.com.br
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (opcional — login de clientes via Google)
# Configurar em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Redis (OPCIONAL) ─────────────────────────────────────
# Se ausente, o app continua funcionando: cache desativado e e-mails enviados
# de forma síncrona. Recomendado em produção para performance e filas BullMQ.
#
# Dev (Docker local):
REDIS_URL=redis://:redis_dev_password@localhost:6379
REDIS_PASSWORD=redis_dev_password
#
# Produção via Upstash (gratuito até 10k comandos/dia):
#   1. Acesse https://redis.upstash.com → Create Database
#   2. Copie a URL no formato: rediss://default:TOKEN@HOST:PORT
# REDIS_URL=rediss://default:TOKEN@HOST:PORT

# ─── Cloudflare R2 (Storage de Imagens) ───────────────────
# Obrigatórias se for fazer upload de imagens em produção.
# Obter em: Cloudflare Dashboard → R2 → criar bucket + API tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=felipesbakery-assets
R2_PUBLIC_URL=https://cdn.felipesbakery.com.br
# URL do endpoint R2: https://<account_id>.r2.cloudflarestorage.com

# ─── Mercado Pago ──────────────────────────────────────────
# (obrigatória em produção) Token de acesso do Mercado Pago.
# Obter em: https://www.mercadopago.com.br/developers/panel/app
# Use TEST-... em desenvolvimento e APP_USR-... em produção.
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxx

# Chave pública (exposta no frontend via NEXT_PUBLIC_)
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-xxxxxxxxxxxx

# Webhook secret para validar notificações do MP (opcional mas recomendado)
MERCADOPAGO_WEBHOOK_SECRET=

# ─── Resend (E-mail Transacional) ──────────────────────────
# (obrigatória se quiser receber e-mails de confirmação)
# Obter em: https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@felipesbakery.com.br
RESEND_FROM_NAME=Felipe's Bakery

# ─── Sentry (Monitoramento — opcional) ────────────────────
# Obter em: https://sentry.io → Project Settings → Client Keys (DSN)
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Auth token para upload de source maps no CI/CD
SENTRY_AUTH_TOKEN=

# ─── Rate Limiting (Upstash REST — alternativa) ───────────
# Opcional. Se preencher, alguns rate limiters usarão o REST API
# do Upstash em vez da conexão TCP do REDIS_URL.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Variáveis Públicas (expostas ao browser) ─────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=5516997684430
NEXT_PUBLIC_SITE_NAME=Felipe's Bakery
NEXT_PUBLIC_SITE_DESCRIPTION=Padaria artesanal de fermentação natural. Pães, ciabattas, focaccias e folhados feitos com ingredientes selecionados.

# ─── Setup / Migrações ────────────────────────────────────
# Protege o endpoint GET /api/setup?secret=VALOR que aplica as migrations.
# Crie qualquer string aleatória e segura; use apenas uma vez.
SETUP_SECRET=TROCAR_segredo_aleatorio_para_setup

# ─── Configurações da Loja (Seed / Bootstrap) ─────────────
# Estes valores são usados apenas no seed inicial (npm run db:seed)
# Após o seed, as configurações são gerenciadas pelo painel admin
SEED_ADMIN_EMAIL=admin@felipesbakery.com.br
SEED_ADMIN_PASSWORD=TROCAR_senha_admin_forte_aqui
SEED_ADMIN_NAME=Felipe
